{
  "name": "pebble-watchface-template",
  "author": "julpel8",
  "description": "A starter template for building a Pebble watchface: time plus up to five configurable info lines (date, weather, sunrise/sunset, steps, a second time zone…), an optional after-dark night theme, full i18n, and an inline HTML config page. Clock layout and widgets inspired by Freakified's Halcyon.",
  "version": "0.0.1",
  "license": "MIT",
  "keywords": [
    "pebble-watchface",
    "template",
    "starter"
  ],
  "private": true,
  "scripts": {
    "check:i18n": "node scripts/check-languages.js"
  },
  "pebble": {
    "displayName": "Watchface Template",
    "uuid": "56cf57ff-0c31-47b6-af9e-cd44295e7f6a",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "capabilities": [
      "location",
      "configurable",
      "health"
    ],
    "watchapp": {
      "onlyShownOnCommunication": false,
      "hiddenApp": false,
      "watchface": true
    },
    "messageKeys": [
      "SETTING_TIME_COLOR",
      "SETTING_SUBTEXT_PRIMARY_COLOR",
      "SETTING_SUBTEXT_SECONDARY_COLOR",
      "SETTING_BG_COLOR",
      "SETTING_USE_LARGE_FONTS",
      "SETTING_SHOW_LEADING_ZERO",
      "SETTING_TIME_FORMAT",
      "SETTING_WIDGET_UPPER_SECONDARY",
      "SETTING_WIDGET_UPPER_PRIMARY",
      "SETTING_WIDGET_LOWER_PRIMARY",
      "SETTING_WIDGET_LOWER_SECONDARY",
      "SETTING_TEMP_UNIT",
      "SETTING_LANGUAGE",
      "SETTING_ALT_CITY_LABEL",
      "ALT_CITY_UTC_OFFSET",
      "SETTING_ALT_CITY2_LABEL",
      "ALT_CITY2_UTC_OFFSET",
      "LOCAL_UTC_OFFSET",
      "REQUEST_UPDATE",
      "WATCH_IS_24H",
      "SETTING_USE_PRIMARY_WIDGET_FONT",
      "SETTING_INFO_LAYOUT"
    ],
    "resources": {
      "media": [
        {
          "file": "images/menuicon.png",
          "menuIcon": true,
          "name": "MENU_ICON",
          "type": "bitmap"
        }
      ]
    }
  },
  "dependencies": {}
}
